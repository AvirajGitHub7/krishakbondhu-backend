# ========================================
# KrishakBondhu Backend Configuration (Example)
# ========================================

# --- MongoDB ---
# Using local MongoDB for development or remote cluster URI
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=krishakbondhu

# --- JWT Authentication ---
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Cloudinary ---
# Add your credentials here to enable image uploads
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name

# --- HuggingFace Model ---
HF_MODEL_NAME=linkanjarad/mobilenet_v2_1.0_224-plant-disease-identification
HF_TOKEN=your_hugging_face_token_here

# --- Server ---
HOST=0.0.0.0
PORT=8000
DEBUG=true

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081
